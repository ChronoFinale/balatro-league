# Team Tour — local dev environment. Copy to `.env`.

# Local Postgres. Run `npm run dev:db` (embedded Postgres, no Docker) in one
# terminal; it serves this URL. Then `npm run db:push` to create the schema.
DATABASE_URL="postgresql://postgres:postgres@localhost:54330/tour_dev"

# Tour Discord bot token (Discord developer portal → your Tour app → Bot).
# Not needed for schema/codegen; required only to run the bot.
DISCORD_TOKEN=""

# ── Auth (NextAuth Discord OAuth — SHARED with the league for one-site SSO) ──
# Use the SAME values as the league so a login on balatroleague.com carries to
# tour.balatroleague.com (and vice-versa):
#   • DISCORD_CLIENT_ID/SECRET — the league's Discord OAuth app (add a redirect
#     URL https://tour.balatroleague.com/api/auth/callback/discord to it; for
#     local dev add http://localhost:4000/api/auth/callback/discord).
#   • AUTH_SECRET — the SAME secret as the league (so this app can read its JWT).
#   • AUTH_COOKIE_DOMAIN — ".balatroleague.com" in prod (shares the cookie);
#     leave UNSET locally (host-only cookie, works standalone on localhost).
# Until these are set, pages render fine; only /api/auth/* needs them.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
AUTH_SECRET=""
# AUTH_COOKIE_DOMAIN=".balatroleague.com"   # prod only — unset for local dev

# ── Permission tiers (who's an admin/TO once signed in; see lib/auth.ts) ──────
# Comma-separated Discord user IDs. The reliable path pre-bot — works across the
# shared SSO. OWNER + TO tiers can use all admin tools.
TOUR_OWNER_DISCORD_IDS=""
TOUR_TO_DISCORD_IDS=""
TOUR_HELPER_DISCORD_IDS=""
# Optional: the Tour Discord guild ID. When set (+ the guilds.members.read grant),
# sign-in reads the user's roles to resolve their tier via RoleBinding too.
TOUR_GUILD_ID=""

# Local dev admin bypass — "1" grants admin without Discord auth (see lib/auth.ts).
TOUR_DEV_ADMIN="1"
