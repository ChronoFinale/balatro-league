# ============================================================================
# LOCAL DEV environment for the BOT (src/).  Copy this to `.env` when you want
# local dev:   cp .env.dev.example .env   (back up your current .env first!)
#
# Nothing here touches Railway/prod. The bot talks to Discord over the Gateway
# (an OUTBOUND WebSocket) — Discord never connects in, so localhost is fine.
# No tunnel / ngrok / public endpoint needed.
# ============================================================================

# --- Local Postgres (installed via winget; see setup notes) ---
# Assumes superuser `postgres` / password `postgres` on port 5432, db created
# as balatro_league_dev. Change if you picked different install values.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/balatro_league_dev"

# --- DEV Discord application (a SECOND app — NOT the deployed bot) ---
# 1. https://discord.com/developers/applications → New Application ("BL Dev")
# 2. Bot tab → Reset Token → paste below.
# 3. OAuth2 → invite it to a PRIVATE test server you own (scopes: bot, applications.commands)
DISCORD_TOKEN=PASTE_DEV_BOT_TOKEN
DISCORD_CLIENT_ID=PASTE_DEV_APP_ID
DISCORD_CLIENT_SECRET=PASTE_DEV_APP_CLIENT_SECRET

# Your PRIVATE test server's ID (Discord → Developer Mode on → right-click
# server icon → Copy Server ID). Per-guild commands register instantly.
DISCORD_GUILD_ID=PASTE_TEST_GUILD_ID

# Your own Discord user ID — the owner gets /admin without needing a role.
LEAGUE_OWNER_DISCORD_ID=PASTE_YOUR_DISCORD_USER_ID

# Optional for solo testing — leave blank and use /league bootstrap-server to
# create channels/roles in the test guild after the bot is in it.
LEAGUE_ADMIN_ROLE_ID=
RESULTS_CHANNEL_ID=
